# ============================================
# Production Environment Variables
# Copy to .env on the production server
# ALL values below MUST be set before deployment
# ============================================

# App
NODE_ENV=production
PORT=3001
CLIENT_URL=https://yourdomain.com

# Database (used by docker-compose to create the PostgreSQL user)
POSTGRES_PASSWORD=GENERATE_A_STRONG_PASSWORD_HERE
DATABASE_URL=postgresql://scl:${POSTGRES_PASSWORD}@postgres:5432/scl_sms

# Redis
REDIS_PASSWORD=GENERATE_A_STRONG_REDIS_PASSWORD_HERE
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# JWT — CRITICAL: generate unique random secrets (min 32 chars)
# Example: openssl rand -base64 48
JWT_SECRET=GENERATE_WITH_openssl_rand_base64_48
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=GENERATE_WITH_openssl_rand_base64_48
JWT_REFRESH_EXPIRES_IN=30d

# Admin account (created on first seed)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_TO_STRONG_ADMIN_PASSWORD
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

# Twilio (LIVE credentials)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_live_auth_token
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SMS Mode: live (production), twilio_test (staging), simulation (dev)
SMS_MODE=live

# Webhook URL — your production domain
WEBHOOK_BASE_URL=https://yourdomain.com

# SMS Sending Limits
MAX_DAILY_MESSAGES_PER_NUMBER=350
MAX_MESSAGES_PER_MINUTE=60
RAMP_UP_ENABLED=true
RAMP_DAY_1_LIMIT=50
RAMP_DAY_2_LIMIT=100
RAMP_DAY_3_LIMIT=150
RAMP_DAY_4_LIMIT=200
RAMP_DAY_5_LIMIT=250
RAMP_DAY_6_LIMIT=300
RAMP_DAY_7_LIMIT=350

# Compliance
COMPLIANCE_QUIET_HOURS_START=20
COMPLIANCE_QUIET_HOURS_END=9
COMPLIANCE_TIMEZONE=America/New_York
SUPPORT_PHONE=(786) 648-7512

# Logging (info for production, debug for troubleshooting)
LOG_LEVEL=info
