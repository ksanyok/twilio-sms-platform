# Server Environment Variables
# Copy to .env and fill in values

# App
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://scl_user:scl_password@localhost:5432/scl_sms_platform

# Redis (for BullMQ job queues)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio Webhook Base URL (ngrok in dev)
WEBHOOK_BASE_URL=http://localhost:3001

# SMS Sending Limits
MAX_DAILY_MESSAGES_PER_NUMBER=350
MAX_MESSAGES_PER_MINUTE=60
RAMP_UP_ENABLED=true
RAMP_DAY_1_LIMIT=50
RAMP_DAY_2_LIMIT=100
RAMP_DAY_3_LIMIT=150
RAMP_DAY_4_LIMIT=200
RAMP_DAY_5_LIMIT=250
RAMP_DAY_6_LIMIT=300
RAMP_DAY_7_LIMIT=350

# Compliance
COMPLIANCE_QUIET_HOURS_START=20
COMPLIANCE_QUIET_HOURS_END=9
COMPLIANCE_TIMEZONE=America/New_York

# Logging
LOG_LEVEL=debug
